////////////////////////////////////////////////////////////////////////////////
// 파일명: color.ps
////////////////////////////////////////////////////////////////////////////////

//////////////
// 타입 정의 //
//////////////
struct PixelInputType
{
    float4 position : SV_POSITION;
    float4 color    : COLOR;
};

////////////////////////////////////////////////////////////////////////////////
// 픽셀 셰이더
////////////////////////////////////////////////////////////////////////////////
float4 ColorPixelShader(PixelInputType input) : SV_TARGET
{
    // 입력 색상을 그대로 픽셀 색상으로 반환합니다.
    return input.color;
}